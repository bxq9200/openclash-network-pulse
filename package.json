{
  "name": "openclash-desktop-widget",
  "version": "1.0.3",
  "description": "A cross-platform desktop widget for OpenClash / Mihomo network status and proxy switching.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node scripts/build-icon.js",
    "prepack": "npm run icon",
    "predist": "npm run icon",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:linux": "electron-builder --linux --publish never",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "electron",
    "openclash",
    "clash",
    "desktop-widget"
  ],
  "author": {
    "name": "bxq9200",
    "email": "bxq9200@users.noreply.github.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bxq9200/openclash-network-pulse.git"
  },
  "homepage": "https://github.com/bxq9200/openclash-network-pulse#readme",
  "bugs": {
    "url": "https://github.com/bxq9200/openclash-network-pulse/issues"
  },
  "build": {
    "appId": "local.openclash.network-pulse",
    "productName": "Network Pulse",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "bxq9200",
      "repo": "openclash-network-pulse"
    },
    "win": {
      "icon": "src/assets/logo.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Network Pulse"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "icon": "src/assets/logo.png",
      "maintainer": "bxq9200 <bxq9200@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
